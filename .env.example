# Content Storage Server Configuration
# Copy this file to .env and customize for your environment

# ==============================================
# Server Configuration
# ==============================================
PORT=8081
HOST=0.0.0.0

# Server Timeouts
READ_TIMEOUT=30s
WRITE_TIMEOUT=30s
REQUEST_TIMEOUT=60s
SHUTDOWN_TIMEOUT=30s

# Connection Limits (prevents connection flood DoS)
MAX_CONNS_PER_HOST=100

# API Key Authentication Security
ALLOW_QUERY_PARAM_AUTH=false  # WARNING: Only enable for development, API keys logged in URLs

# ==============================================
# Storage Configuration
# ==============================================
DATA_DIR=/app/data
BACKUP_DIR=/app/backups

# ==============================================
# Performance Settings
# ==============================================
PERFORMANCE_MODE=true
CACHE_SIZE=134217728
ENABLE_CACHE_WARMUP=true

# Write Queue Configuration
WRITE_QUEUE_SIZE=1000
WRITE_QUEUE_BATCH_SIZE=10
WRITE_QUEUE_BATCH_TIMEOUT=100ms
WRITE_QUEUE_MAX_MULTIPLIER=10  # Max queue size = initial * multiplier

# ==============================================
# Backup Settings
# ==============================================
BACKUP_INTERVAL=6h
MAX_BACKUPS=7

# ==============================================
# Garbage Collection
# ==============================================
GC_INTERVAL=30m
GC_THRESHOLD=0.7
ENABLE_ADAPTIVE_GC=true

# ==============================================
# Security Settings
# ==============================================
ENABLE_AUTH=false
API_KEY=
ALLOWED_ORIGINS=*
ALLOWED_IPS=

# Content Type Restrictions
ALLOWED_CONTENT_TYPES=application/json,text/plain

# Content Size Limits
MAX_CONTENT_SIZE=10485760

# Validation Limits
MAX_ID_LENGTH=255
MAX_TYPE_LENGTH=100
MAX_PAGINATION_LIMIT=1000
MAX_ACCESS_LIMIT=1000000

# ==============================================
# Rate Limiting
# ==============================================
THROTTLE_LIMIT=1000
THROTTLE_BACKLOG_LIMIT=50
THROTTLE_BACKLOG_TIMEOUT=30s

# API Rate Limiting
API_RATE_LIMIT_PERIOD=1m
API_RATE_LIMIT_BURST=100

# Echo Rate Limiting
ECHO_RATE_LIMIT=100
ECHO_BURST_LIMIT=50
ECHO_RATE_LIMIT_EXPIRES_IN=1h

# ==============================================
# Compression
# ==============================================
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=5
COMPRESSION_TYPES=text/html,text/plain,application/json,text/javascript,text/css,application/javascript

# ==============================================
# Logging Configuration
# ==============================================
# Enable/Disable specific log levels
ENABLE_ERROR_LOGGING=true
ENABLE_WARN_LOGGING=true
ENABLE_INFO_LOGGING=true
ENABLE_DEBUG_LOGGING=false

# Enable/Disable specific logging categories
ENABLE_REQUEST_LOGGING=true
ENABLE_MANAGEMENT_LOGGING=true
ENABLE_SECURITY_LOGGING=true
ENABLE_CRITICAL_LOGGING=true
SUPPRESS_CRUD_LOGGING=false
ENABLE_VALIDATION_LOGGING=false

# ==============================================
# TLS/HTTPS (optional)
# ==============================================
ENABLE_TLS=false
TLS_PORT=443
TLS_CACHE_DIR=/app/certs
TLS_HOSTS=localhost,example.com
ENABLE_HTTPS_ONLY=false

# ==============================================
# Emergency Recovery
# ==============================================
ENABLE_EMERGENCY_RECOVERY=true
EMERGENCY_RECOVERY_DIR=backups/emergency-recovery
EMERGENCY_TIMEOUT=5s

# ==============================================
# Profiler (development only - disable in production)
# ==============================================
ENABLE_PROFILER=false
