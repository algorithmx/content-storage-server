# Server Configuration
PORT=8081
HOST=0.0.0.0

# Storage Configuration
DATA_DIR=/app/data
BACKUP_DIR=/app/backups

# Performance Settings
PERFORMANCE_MODE=true
CACHE_SIZE=134217728
ENABLE_CACHE_WARMUP=true

# Backup Settings
BACKUP_INTERVAL=6h
MAX_BACKUPS=7

# Security Settings
ENABLE_AUTH=false
API_KEY=
ALLOWED_ORIGINS=*

# Rate Limiting
THROTTLE_LIMIT=1000
THROTTLE_BACKLOG_LIMIT=50

# Compression
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=5

# Logging
ENABLE_ERROR_LOGGING=true
ENABLE_WARN_LOGGING=true
ENABLE_VALIDATION_LOGGING=false

# TLS/HTTPS (optional)
ENABLE_TLS=false
TLS_PORT=443
TLS_CACHE_DIR=/app/certs
ENABLE_HTTPS_ONLY=false

# Emergency Recovery
ENABLE_EMERGENCY_RECOVERY=false

# Profiler (development only)
ENABLE_PROFILER=false
